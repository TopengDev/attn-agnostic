# Build artifacts
/bin/
/dist/
*.exe
# Stray binaries built into the repo ROOT only. A bare `attn-smoke`/`attnd`
# pattern would ALSO match the cmd/attn-smoke/ + cmd/attnd/ SOURCE dirs and
# silently exclude them from git — so anchor these to the repo root.
/attn-smoke
/attnd
/attnctl
/attn
/attn-mcp

# Go
*.test
*.out
/vendor/

# Local identity / secrets — NEVER commit private keys
*.key
*.hex
.env
.env.*
/keys/

# Local daemon state (SQLite db + WAL/SHM) if attnd is run inside the repo
*.db
*.db-shm
*.db-wal

# Upstream study clone (read-only reference, not part of this repo)
/upstream-study/

# Interop harness deps (regenerable via `bun install`)
/testdata/interop/node_modules/
# NOTE: testdata/vectors.json IS committed — it uses a well-known PUBLIC
# throwaway test key, so `go test ./...` is self-contained without bun.

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/
